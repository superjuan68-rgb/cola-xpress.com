# ColaXpress production rules

DirectoryIndex index.html
AddType image/webp .webp

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Normalize the homepage to the canonical root URL.
  RewriteRule ^index\.html$ / [R=301,L]

  # Rescue legacy flat slugs that used to live at the root.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/grow/$1 -f
  RewriteRule ^([A-Za-z0-9-]+\.html)$ /grow/$1 [R=301,L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/learn/$1 -f
  RewriteRule ^([A-Za-z0-9-]+\.html)$ /learn/$1 [R=301,L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/equipment/$1 -f
  RewriteRule ^([A-Za-z0-9-]+\.html)$ /equipment/$1 [R=301,L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{DOCUMENT_ROOT}/guides/$1 -f
  RewriteRule ^([A-Za-z0-9-]+\.html)$ /guides/$1 [R=301,L]

  # Keep internal work artifacts out of the public site if the whole folder is deployed.
  RewriteRule ^(docs|tools|visual-qa)(/|$) - [R=404,L]
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml application/xml application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 5 minutes"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|png|jpg|jpeg|gif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|xml|txt)$">
    Header set Cache-Control "public, max-age=300"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
